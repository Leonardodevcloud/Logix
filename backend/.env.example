# Servidor
PORT=3000
CORS_ORIGIN=https://app.logix.com.br,https://portal.logix.com.br

# Banco PostgreSQL (Railway, Supabase, VPS... — qualquer DATABASE_URL Postgres)
DATABASE_URL=postgres://usuario:senha@host:5432/banco
# SSL: managed/proxy público = true (padrão). Postgres INTERNO do Railway (rede privada) = false
DB_SSL=true
DB_POOL_MAX=5   # enxuto p/ instância pequena (menos RAM no banco e na app)

# JWT dual-token
JWT_ACCESS_SECRET=troque-por-um-segredo-forte
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DIAS=7

# Integrações
ORS_API_KEY=sua-chave-openrouteservice
DOMINIO_BASE=logix.com.br

# Economia: cron roda DENTRO da API (1 container). Ao escalar p/ N instâncias,
# rode o worker separado e defina WORKER_EMBUTIDO=false.
WORKER_EMBUTIDO=true
# Retenção de rastreamento (dias) — menor = menos volume de banco = mais barato
RASTREAMENTO_RETENCAO_DIAS=30

# Seed do super_admin (npm run seed)
SEED_ADMIN_NOME=Super Admin
SEED_ADMIN_EMAIL=
SEED_ADMIN_SENHA=

# Smoke-test (npm run smoke)
BASE_URL=http://localhost:3000
ADMIN_EMAIL=
ADMIN_SENHA=
